#include <Servo.h>

// Pin Definitions
#define SERVO_PIN 9
#define TRIG_PIN 6
#define ECHO_PIN 7
#define BUZZER_PIN 5
#define LED_PIN 4
#define JOY_BTN_PIN 2
#define JOY_X_PIN A0

Servo radarServo;

bool joystickMode = false;

int currentAngle = 90;
int sweepDir = 1;
const int detectDistance = 20;  // cm - alarm threshold

unsigned long lastBtnPress = 0;
const unsigned long debounceDelay = 300;

const int AUTO_SWEEP_STEP = 5;
const int JOYSTICK_MAX_SPEED = 8;

void setup() {
  Serial.begin(9600);

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  pinMode(BUZZER_PIN, OUTPUT);
  pinMode(LED_PIN, OUTPUT);
  pinMode(JOY_BTN_PIN, INPUT_PULLUP);

  digitalWrite(LED_PIN, LOW);
  noTone(BUZZER_PIN);

  delay(300);

  radarServo.attach(SERVO_PIN);
  radarServo.write(currentAngle);

  Serial.println("Radar system running...");
}

void loop() {
  checkModeToggle();

  long distance = getDistanceCM();
  bool objectDetected = (distance > 0 && distance <= detectDistance);

  if (objectDetected) {
    alarmOn();
  } else {
    alarmOff();
    if (joystickMode) {
      handleJoystick();
    } else {
      autoSweep();
    }
  }

  if (distance > 0) {
    Serial.print(currentAngle);
    Serial.print(",");
    Serial.print(distance);
    Serial.println(".");
  }

  delay(30);
}

void checkModeToggle() {
  if (digitalRead(JOY_BTN_PIN) == LOW && millis() - lastBtnPress > debounceDelay) {
    joystickMode = !joystickMode;
    lastBtnPress = millis();
    Serial.print("Mode: ");
    Serial.println(joystickMode ? "Joystick" : "Auto-sweep");
  }
}

long getDistanceCM() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  long duration = pulseIn(ECHO_PIN, HIGH, 30000);
  if (duration == 0) return -1;

  return duration * 0.0343 / 2;
}

void alarmOn() {
  tone(BUZZER_PIN, 12, 5000); 
  digitalWrite(LED_PIN, HIGH);
}

void alarmOff() {
  digitalWrite(LED_PIN, LOW);
  noTone(BUZZER_PIN);
}

void autoSweep() {
  currentAngle += sweepDir * AUTO_SWEEP_STEP;
  if (currentAngle >= 180) {
    currentAngle = 180;
    sweepDir = -1;
  } else if (currentAngle <= 0) {
    currentAngle = 0;
    sweepDir = 1;
  }
  radarServo.write(currentAngle);
}

void handleJoystick() {
  int xVal = analogRead(JOY_X_PIN);
  int deadzone = 60;
  int center = 512;

  if (xVal > center + deadzone) {
    int speed = map(xVal, center + deadzone, 1023, 1, JOYSTICK_MAX_SPEED);
    currentAngle = constrain(currentAngle + speed, 0, 180);
  } else if (xVal < center - deadzone) {
    int speed = map(xVal, center - deadzone, 0, 1, JOYSTICK_MAX_SPEED);
    currentAngle = constrain(currentAngle - speed, 0, 180);
  }

  radarServo.write(currentAngle);
}
